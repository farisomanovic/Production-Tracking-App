// This tells Prisma to generate a JavaScript/TypeScript client.
// This tells Prisma "when I run npx prisma generate, produce a JavaScript client library." 
// That client library is what gives you prisma.operator.findMany() and 
// all the other methods you use in your route files. 
// Without this block, Prisma wouldn't know what kind of code to generate.
generator client {
  provider = "prisma-client-js"
}

// This tells Prisma which database to connect to and how
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Active field is for soft delete. If we hard delete an operator 
// we would delete all the runs related to him.
// Also its only liked to productionRun we dont need operators anywhere else.
model Operator {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)

  productionRuns ProductionRun[]
}

// Same goes for machine. Also code is optional since some machines might not have it.
// Its linked to machineParameter table since one parameter can be present at many machines,
// and one machine can have many parameters. Same goes for products. And we also need it
// in productionRun since we want to know on which machine did we create the run etc.
model Machine {
  id       String  @id @default(uuid())
  name     String
  code     String?  @unique
  active   Boolean @default(true)

  machineParameters MachineParameter[]
  machineProducts   MachineProduct[]
  productionRuns    ProductionRun[]
}

// Unit optional since some parameters are unitless. Linked to machineParameter as explained previously.
model Parameter {
  id          String  @id @default(uuid())
  name        String
  unit        String?
  description String?

  machineParameters MachineParameter[]
}

// Joint table for machine and parameter. Has machneId and parameterId as foregin keys that point
// to machine and parameter tables respectively. DisplayOrder is used to determine in what order 
// to display parameters since when i am starting to log parameters i am at the top of the machine i dont want
// to log parameter from the bottom of machine. Linked to runParameterValues that will be explained in the respected table.
// 2 Unique constraints since one machine can not be linked to the same parameter twice and
// one parameter cant have same displayOrder priority as another one.
model MachineParameter {
  id           String @id @default(uuid())
  displayOrder Int    @default(0)

  machineId   String
  parameterId String

  machine   Machine   @relation(fields: [machineId], references: [id])
  parameter Parameter @relation(fields: [parameterId], references: [id])

  runParameterValues RunParameterValue[]

  @@unique([machineId, parameterId])
  @@unique([machineId, displayOrder])
}

// All the optional fields are optional since some products have it some not.
// Linked to machineProducts as explained previously. Linked to recepies because we need to specify
// for what product is the recepie.
// Linked to runOutput since the output is products. Linked to productionRun since we want to know what
// did we want to produce that run.
model Product {
  id          String @id @default(uuid())
  name        String
  code        String @unique
  widthMm     Float?
  thicknessMm Float?
  lengthM     Float?
  description String?
  unit        String

  machineProducts MachineProduct[]
  recipes         Recipe[]
  runOutputs      RunOutput[]
  productionRuns  ProductionRun[]
}

// Joint table for machine and products as explained previously.
model MachineProduct {
  id String @id @default(uuid())

  machineId String
  productId String

  machine Machine @relation(fields: [machineId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([machineId, productId])
}

// stockQty field to track the stock of the material. Linked to recepieItem since one recepieItem
// is actually material and linked to materialUsages to know how much material and which material
// was used during the run.
model Material {
  id       String @id @default(uuid())
  name     String
  unit     String
  supplier String?
  stockQty Float  @default(0)

  recipeItems    RecipeItem[]
  materialUsages MaterialUsage[]
}

// One recepie can have multiple materials and one material can be in multiple recepies.
// That is why we have recepieItem to specify to what recepie does what belong.
// isDefault used to auto-choose it on the form.
// Linked to productionRun since we want to know what recepie was used.
model Recipe {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  notes     String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  recipeItems    RecipeItem[]
  productionRuns ProductionRun[]
}

// Table to connect materials to recepie and specify their percentage.
model RecipeItem {
  id           String @id @default(uuid())
  percentage   Float
  plannedQtyKg Float?

  recipeId   String
  materialId String

  recipe   Recipe   @relation(fields: [recipeId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([recipeId, materialId])
}

// The main table used to connect everything. Status used so the form can be submitted in 
// 2 parts.
model ProductionRun {
  id              String    @id @default(uuid())
  date            DateTime  @db.Date
  startTime       DateTime  @db.Timestamp
  endTime         DateTime? @db.Timestamp
  warmupStartTime DateTime? @db.Timestamp
  stableStartTime DateTime? @db.Timestamp
  energyStart     Float?
  energyEnd       Float?
  notes           String?
  potentialBuyer  String?
  status          String    @default("in_progress")

  operatorId String
  machineId  String
  productId  String
  recipeId   String

  operator Operator @relation(fields: [operatorId], references: [id])
  machine  Machine  @relation(fields: [machineId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  recipe   Recipe  @relation(fields: [recipeId], references: [id])

  runParameterValues RunParameterValue[]
  materialUsages     MaterialUsage[]
  runOutputs         RunOutput[]
}

// Used to record the actual values of parameter each run.
model RunParameterValue {
  id         String   @id @default(uuid())
  value      Float
  recordedAt DateTime @default(now())

  productionRunId    String
  machineParameterId String

  productionRun    ProductionRun    @relation(fields: [productionRunId], references: [id])
  machineParameter MachineParameter @relation(fields: [machineParameterId], references: [id])

  @@unique([productionRunId, machineParameterId])
}

// Used to record how much material was used during a run.
model MaterialUsage {
  id             String @id @default(uuid())
  quantityUsed   Float

  productionRunId String
  materialId      String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  material      Material      @relation(fields: [materialId], references: [id])

  @@unique([productionRunId, materialId])
}

// Used to track what was made during a run.
model RunOutput {
  id               String  @id @default(uuid())
  quantityProduced Float
  grossWeightKg    Float?
  scrapKg          Float?

  productionRunId String
  productId       String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}