// ---------------------------------------------------------
// PRODUCTION TRACKING SCHEMA
// ---------------------------------------------------------
// Core Entities: Operator, Machine, Product, Material
// Config Entities: Recipe (Product blueprint), MachineParameter (Machine setup)
// Transactional Entity: ProductionRun (The central event)
// ---------------------------------------------------------
// This file defines the database schema for the production tracking application using Prisma. 
// The schema is designed to allow for soft deletion of operators and machines, as well as tracking of material usage and run outputs.
// The generator block specifies that Prisma should generate a JavaScript/TypeScript client, 
// which will be used to interact with the database in the application code.
// This tells Prisma "when I run npx prisma generate, produce a JavaScript client library." 
// That client library is what gives prisma.operator.findMany() and all the other methods used in route files. 
// Without this block, Prisma wouldn't know what kind of code to generate.
generator client {
  provider = "prisma-client-js"
}

// This block defines the connection to the database. It specifies that we are using PostgreSQL as our database provider,
// and that the connection URL should be taken from the DATABASE_URL environment variable.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Active status is for soft deletion.
model Operator {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)

  productionRuns ProductionRun[]
}
 
// Optional code is for unique identification, and active status for soft deletion.
model Machine {
  id       String  @id @default(uuid())
  name     String
  code     String?  @unique
  active   Boolean @default(true)

  machineParameters MachineParameter[]
  machineProducts   MachineProduct[]
  productionRuns    ProductionRun[]
}

model Parameter {
  id          String  @id @default(uuid())
  name        String
  unit        String?
  description String?

  machineParameters MachineParameter[]
}


// displayOrder field is used to specify the order of parameters on the form.
// We have a unique constraint on machineId and parameterId to ensure that the same 
// parameter is not added multiple times to the same machine.
// We also have a unique constraint on machineId and displayOrder to ensure that the same 
// display order is not used for multiple parameters on the same machine.
model MachineParameter {
  id           String @id @default(uuid())
  displayOrder Int    @default(0)

  machineId   String
  parameterId String

  machine   Machine   @relation(fields: [machineId], references: [id])
  parameter Parameter @relation(fields: [parameterId], references: [id])

  runParameterValues RunParameterValue[]

  @@unique([machineId, parameterId])
  @@unique([machineId, displayOrder])
}

// We have a unique constraint on the code field to ensure that each product has a unique code.
model Product {
  id          String @id @default(uuid())
  name        String
  code        String @unique
  widthMm     Float?
  thicknessMm Float?
  lengthM     Float?
  description String?
  unit        String

  machineProducts MachineProduct[]
  recipes         Recipe[]
  runOutputs      RunOutput[]
  productionRuns  ProductionRun[]
}

// We have a unique constraint on machineId and productId to ensure that the same 
// machine-product combination is not added multiple times.
model MachineProduct {
  id String @id @default(uuid())

  machineId String
  productId String

  machine Machine @relation(fields: [machineId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([machineId, productId])
}

model Material {
  id       String @id @default(uuid())
  name     String
  unit     String
  supplier String?
  stockQty Float  @default(0)

  recipeItems    RecipeItem[]
  materialUsages MaterialUsage[]
}

// Recipe is a mixture of materials used in production of a product. A product can have multiple recipes, 
// but only one can be the default recipe.
// isDefault is used to indicate if it is the default recipe for the product.
model Recipe {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  notes     String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  recipeItems    RecipeItem[]
  productionRuns ProductionRun[]
}

// This table is used to connect recipes and materials, and specify the percentage of each material in the recipe,
// as well as the planned quantity in kg for each material. We have a unique constraint on recipeId 
// and materialId to ensure that the same material is not added multiple times to the same recipe
model RecipeItem {
  id           String @id @default(uuid())
  percentage   Float
  plannedQtyKg Float?

  recipeId   String
  materialId String

  recipe   Recipe   @relation(fields: [recipeId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([recipeId, materialId])
}

// The main table used to connect everything. Status used so the form can be submitted in 
// 2 parts.
model ProductionRun {
  id              String    @id @default(uuid())
  date            DateTime  @db.Date
  startTime       DateTime  @db.Timestamp
  endTime         DateTime? @db.Timestamp
  warmupStartTime DateTime? @db.Timestamp
  stableStartTime DateTime? @db.Timestamp
  energyStart     Float?
  energyEnd       Float?
  notes           String?
  potentialBuyer  String?
  status          String    @default("in_progress")

  operatorId String
  machineId  String
  productId  String
  recipeId   String

  operator Operator @relation(fields: [operatorId], references: [id])
  machine  Machine  @relation(fields: [machineId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  recipe   Recipe  @relation(fields: [recipeId], references: [id])

  runParameterValues RunParameterValue[]
  materialUsages     MaterialUsage[]
  runOutputs         RunOutput[]
}

// This table is used to record the values of machine parameters during a production run. 
// We have a unique constraint on productionRunId and machineParameterId to ensure that the same parameter 
// value is not recorded multiple times for the same run.
model RunParameterValue {
  id         String   @id @default(uuid())
  value      Float
  recordedAt DateTime @default(now())

  productionRunId    String
  machineParameterId String

  productionRun    ProductionRun    @relation(fields: [productionRunId], references: [id])
  machineParameter MachineParameter @relation(fields: [machineParameterId], references: [id])

  @@unique([productionRunId, machineParameterId])
}

// This table is used to record the quantity of each material used during a production run.
// We have a unique constraint on productionRunId and materialId to ensure that the same material usage
// is not recorded multiple times for the same run.
// quantityUsed is the actual quantity used during the run, which may differ from the planned quantity in the recipe.
model MaterialUsage {
  id             String @id @default(uuid())
  quantityUsed   Float

  productionRunId String
  materialId      String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  material      Material      @relation(fields: [materialId], references: [id])

  @@unique([productionRunId, materialId])
}

// This table is used to record the output of a production run, including the quantity produced, 
// gross weight, and scrap weight.
model RunOutput {
  id               String  @id @default(uuid())
  quantityProduced Float
  grossWeightKg    Float?
  scrapKg          Float?

  productionRunId String
  productId       String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}