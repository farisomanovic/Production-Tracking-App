// ---------------------------------------------------------
// Production Tracking Schema
// ---------------------------------------------------------
// Core entities: Operator, Machine, Product, Material
// Configuration entities: Recipe, MachineParameter, MachineProduct
// Transactional entity: ProductionRun
// ---------------------------------------------------------
// Defines the relational model used by the backend. Operators and machines use
// soft deletion through active flags so historical production runs remain valid.
// Prisma generates the JavaScript client consumed by the route handlers.
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL connection settings are read from DATABASE_URL.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Operators are soft-deleted with active=false to preserve production history.
model Operator {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)

  productionRuns ProductionRun[]
}
 
// Machines may have a unique operational code and are soft-deleted with active=false.
model Machine {
  id       String  @id @default(uuid())
  name     String
  code     String?  @unique
  active   Boolean @default(true)

  machineParameters MachineParameter[]
  machineProducts   MachineProduct[]
  productionRuns    ProductionRun[]
}

model Parameter {
  id          String  @id @default(uuid())
  name        String
  unit        String?
  description String?

  machineParameters MachineParameter[]
}

// Links parameters to machines and defines their form order.
// @@unique([machineId, parameterId]) prevents assigning the same parameter twice.
// @@unique([machineId, displayOrder]) prevents two parameters sharing one position.
model MachineParameter {
  id           String @id @default(uuid())
  displayOrder Int    @default(0)

  machineId   String
  parameterId String

  machine   Machine   @relation(fields: [machineId], references: [id])
  parameter Parameter @relation(fields: [parameterId], references: [id])

  runParameterValues RunParameterValue[]

  @@unique([machineId, parameterId])
  @@unique([machineId, displayOrder])
}

// Product codes are unique so production outputs can be identified consistently.
model Product {
  id          String @id @default(uuid())
  name        String
  code        String @unique
  widthMm     Float?
  thicknessMm Float?
  lengthM     Float?
  description String?
  unit        String

  machineProducts MachineProduct[]
  recipes         Recipe[]
  runOutputs      RunOutput[]
  productionRuns  ProductionRun[]
}

// Links machines to compatible products; the unique pair prevents duplicates.
model MachineProduct {
  id String @id @default(uuid())

  machineId String
  productId String

  machine Machine @relation(fields: [machineId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([machineId, productId])
}

model Material {
  id       String @id @default(uuid())
  name     String
  unit     String
  supplier String?
  stockQty Float  @default(0)

  recipeItems    RecipeItem[]
  materialUsages MaterialUsage[]
}

// A recipe is a material formula for a product. A product may have multiple
// recipes, with isDefault marking the preferred formula.
model Recipe {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  notes     String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  recipeItems    RecipeItem[]
  productionRuns ProductionRun[]
}

// Connects recipes to materials and stores each material's formula percentage.
// The unique pair prevents adding the same material twice to one recipe.
model RecipeItem {
  id           String @id @default(uuid())
  percentage   Float
  plannedQtyKg Float?

  recipeId   String
  materialId String

  recipe   Recipe   @relation(fields: [recipeId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([recipeId, materialId])
}

// Central production event. status supports a two-step workflow: start a run,
// then complete it with measurements, material usage, and outputs.
model ProductionRun {
  id              String    @id @default(uuid())
  date            DateTime  @db.Date
  startTime       DateTime  @db.Timestamp
  endTime         DateTime? @db.Timestamp
  warmupStartTime DateTime? @db.Timestamp
  stableStartTime DateTime? @db.Timestamp
  energyStart     Float?
  energyEnd       Float?
  notes           String?
  potentialBuyer  String?
  status          String    @default("in_progress")

  operatorId String
  machineId  String
  productId  String
  recipeId   String

  operator Operator @relation(fields: [operatorId], references: [id])
  machine  Machine  @relation(fields: [machineId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  recipe   Recipe  @relation(fields: [recipeId], references: [id])

  runParameterValues RunParameterValue[]
  materialUsages     MaterialUsage[]
  runOutputs         RunOutput[]
}

// Stores measured machine-parameter values for a run.
// The unique pair prevents recording the same parameter twice for one run.
model RunParameterValue {
  id         String   @id @default(uuid())
  value      Float
  recordedAt DateTime @default(now())

  productionRunId    String
  machineParameterId String

  productionRun    ProductionRun    @relation(fields: [productionRunId], references: [id])
  machineParameter MachineParameter @relation(fields: [machineParameterId], references: [id])

  @@unique([productionRunId, machineParameterId])
}

// Stores actual material consumption for a run. quantityUsed may differ from
// the planned recipe quantity.
// The unique pair prevents duplicate usage rows for the same material in a run.
model MaterialUsage {
  id             String @id @default(uuid())
  quantityUsed   Float

  productionRunId String
  materialId      String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  material      Material      @relation(fields: [materialId], references: [id])

  @@unique([productionRunId, materialId])
}

// Stores production output quantities plus optional weight and scrap metrics.
model RunOutput {
  id               String  @id @default(uuid())
  quantityProduced Float
  grossWeightKg    Float?
  scrapKg          Float?

  productionRunId String
  productId       String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}
