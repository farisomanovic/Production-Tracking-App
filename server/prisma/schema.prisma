// @file schema.prisma
// @description Data model for the production tracker: master data (Operator,
// Machine, Product, Material, Parameter), configuration links (MachineParameter,
// MachineProduct, Recipe/RecipeItem), and transactional run records
// (ProductionRun + its children). Query logic does NOT belong here — routes own it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL: full Postgres connection string (user, password, host, port,
  // db name). Loaded by Prisma itself from server/.env — if it is missing, every
  // prisma CLI command and client query fails at startup with a clear error.
  url      = env("DATABASE_URL")
}

// Soft delete via `active` instead of row deletion: ProductionRun history keeps a
// valid foreign key, and a deactivated operator can be reactivated later.
model Operator {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)

  productionRuns ProductionRun[]
}

// `code` is optional because older machines were entered before codes existed;
// the unique constraint still holds for the ones that have one (Postgres treats
// NULLs as distinct). Soft-deleted via `active`, same reasoning as Operator.
model Machine {
  id       String  @id @default(uuid())
  name     String
  code     String?  @unique
  active   Boolean @default(true)

  machineParameters MachineParameter[]
  machineProducts   MachineProduct[]
  productionRuns    ProductionRun[]
}

// A measurement TYPE (e.g. "Melt temp"), not a value — values live in
// RunParameterValue, and machine assignment lives in MachineParameter.
// TODO: name is not unique, but the XLSX export matches columns by name —
// two parameters with the same name silently merge in reports. todo.md Group 5 #5.
model Parameter {
  id          String  @id @default(uuid())
  name        String
  unit        String?
  description String?

  machineParameters MachineParameter[]
}

// The unique pair blocks double-linking a parameter; the unique displayOrder pair
// blocks two fields claiming one form position.
// TODO: @@unique([machineId, displayOrder]) also makes SWAPPING two positions
// impossible in single updates (first write collides) — consider dropping it,
// since orderBy handles ties harmlessly. todo.md Group 5 #2.
model MachineParameter {
  id           String @id @default(uuid())
  displayOrder Int    @default(0)

  machineId   String
  parameterId String

  machine   Machine   @relation(fields: [machineId], references: [id])
  parameter Parameter @relation(fields: [parameterId], references: [id])

  runParameterValues RunParameterValue[]

  @@unique([machineId, parameterId])
  @@unique([machineId, displayOrder])
}

// `code` is the human-facing product identifier (labels, Excel reports), which is
// why it is unique while `name` is not.
model Product {
  id          String @id @default(uuid())
  name        String
  code        String @unique
  widthMm     Float?
  thicknessMm Float?
  lengthM     Float?
  description String?
  unit        String

  machineProducts MachineProduct[]
  recipes         Recipe[]
  runOutputs      RunOutput[]
  productionRuns  ProductionRun[]
}

// Compatibility whitelist: the new-run wizard only offers products linked to the
// chosen machine. The unique pair prevents duplicate links.
model MachineProduct {
  id String @id @default(uuid())

  machineId String
  productId String

  machine Machine @relation(fields: [machineId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([machineId, productId])
}

// stockQty is live inventory: decremented by run completion, incremented by run
// deletion and manual deliveries — all in kg-equivalent of `unit`.
// TODO: no CHECK (stockQty >= 0) — concurrent completions can drive it negative.
// todo.md Group 2 #4.
// TODO: name is not unique; export matches material columns by name. Group 5 #5.
model Material {
  id       String @id @default(uuid())
  name     String
  unit     String
  supplier String?
  stockQty Float  @default(0)

  recipeItems    RecipeItem[]
  materialUsages MaterialUsage[]
}

// A product can have several formulas (e.g. virgin vs. regranulate mix);
// isDefault marks the one the wizard preselects.
// TODO: nothing enforces ONE default per product — several can be flagged and the
// wizard picks arbitrarily. todo.md Group 5 #6.
model Recipe {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  notes     String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  recipeItems    RecipeItem[]
  productionRuns ProductionRun[]
}

// One material's share of a recipe. Percentages (not absolute kg) so the same
// formula scales to any batch size; plannedQtyKg is an optional convenience for
// a typical batch. The unique pair prevents listing a material twice.
model RecipeItem {
  id           String @id @default(uuid())
  percentage   Float
  plannedQtyKg Float?

  recipeId   String
  materialId String

  recipe   Recipe   @relation(fields: [recipeId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([recipeId, materialId])
}

// The central transactional record. Two-step lifecycle: created as in_progress
// with header data only, then /complete adds measurements + outputs and flips
// status. `date` is the production day (DATE, no time) used for filtering;
// startTime/endTime carry the clock times.
// TODO: status is a raw string — an enum (in_progress | completed) would make
// typos unrepresentable. todo.md Group 5 #4.
// TODO: no indexes on machineId/operatorId/productId/status/date although every
// list query filters on them (Postgres does not auto-index FKs). Group 5 #1.
// TODO: children below use default RESTRICT — onDelete: Cascade would let the DB
// handle run deletion instead of manual deleteMany calls. Group 2 #4.
model ProductionRun {
  id              String    @id @default(uuid())
  date            DateTime  @db.Date
  startTime       DateTime  @db.Timestamp
  endTime         DateTime? @db.Timestamp
  warmupStartTime DateTime? @db.Timestamp
  stableStartTime DateTime? @db.Timestamp
  energyStart     Float?
  energyEnd       Float?
  notes           String?
  potentialBuyer  String?
  status          String    @default("in_progress")

  operatorId String
  machineId  String
  productId  String
  recipeId   String

  operator Operator @relation(fields: [operatorId], references: [id])
  machine  Machine  @relation(fields: [machineId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  recipe   Recipe  @relation(fields: [recipeId], references: [id])

  runParameterValues RunParameterValue[]
  materialUsages     MaterialUsage[]
  runOutputs         RunOutput[]
}

// One measured value per machine parameter per run — the unique pair enforces
// that, and it is also what accidentally blocks double-completion today (see
// the TOCTOU note in productionRuns.js).
model RunParameterValue {
  id         String   @id @default(uuid())
  value      Float
  recordedAt DateTime @default(now())

  productionRunId    String
  machineParameterId String

  productionRun    ProductionRun    @relation(fields: [productionRunId], references: [id])
  machineParameter MachineParameter @relation(fields: [machineParameterId], references: [id])

  @@unique([productionRunId, machineParameterId])
}

// Actual consumption per run — may differ from the recipe's planned percentages,
// which is exactly the deviation the business wants to see. The unique pair
// prevents duplicate rows per material within one run.
model MaterialUsage {
  id             String @id @default(uuid())
  quantityUsed   Float

  productionRunId String
  materialId      String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  material      Material      @relation(fields: [materialId], references: [id])

  @@unique([productionRunId, materialId])
}

// Deliberately NO unique pair here: one run may output the same product in
// several batches (separate rows with their own weight/scrap).
// TODO: productionRunId has no index (the other children get one from their
// @@unique prefix) — detail reads and deletes scan. todo.md Group 5 #1.
model RunOutput {
  id               String  @id @default(uuid())
  quantityProduced Float
  grossWeightKg    Float?
  scrapKg          Float?

  productionRunId String
  productId       String

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}
